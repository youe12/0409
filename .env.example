# ============================================
# 儿童天赋测评工具 - 环境变量配置
# ============================================

# 复制此文件为 .env.local 并填写实际值

# API密钥（必填）- 从 Coze 平台获取
COZE_API_KEY=your_api_key_here

# 项目环境（开发: DEV, 生产: PROD）
COZE_PROJECT_ENV=DEV

# 服务端口（默认5000）
DEPLOY_RUN_PORT=5000

# 工作目录（通常不需要修改）
COZE_WORKSPACE_PATH=/workspace/projects

# 默认访问域名（生产环境需要）
# COZE_PROJECT_DOMAIN_DEFAULT=https://your-domain.com
